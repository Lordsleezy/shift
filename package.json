{
  "name": "shift-by-sentinel",
  "version": "0.1.0",
  "description": "Shift by Sentinel is a cross-platform OS picker and installer for non-technical users.",
  "main": "src/main/main.js",
  "author": "Sentinel Prime",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "start": "electron .",
    "build:renderer": "vite build && node scripts/copy-assets.js",
    "build": "npm run build:renderer && electron-builder",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.2.1",
    "vite": "5.4.11",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "electron": "22.3.27",
    "electron-builder": "24.13.3",
    "tailwindcss": "3.4.17",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20",
    "concurrently": "9.1.0",
    "wait-on": "8.0.1",
    "cross-env": "7.0.3"
  },
  "devDependencies": {},
  "build": {
    "appId": "org.sentinelprime.shift",
    "productName": "Shift by Sentinel",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/shared/**/*",
      "companion/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    }
  }
}
